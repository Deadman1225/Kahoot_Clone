# =====================================================================
# Node.js Backend Rules
# =====================================================================
# Dependency directory (Mandated by submission guidelines)
node_modules/

# Logs
logs
*.log
npm-debug.log*

# Environment Variables
# (Ignore the active .env secret file, but allow tracking of the submission's env.txt)
.env
.env.production
.env.development

# =====================================================================
# Flutter/Dart Default Rules (From your player_app folder)
# =====================================================================
# Miscellaneous
*.class
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# =====================================================================
# Submission Specific Files
# =====================================================================
# Prevent tracking your final submission zip archive inside your repository
*.zip